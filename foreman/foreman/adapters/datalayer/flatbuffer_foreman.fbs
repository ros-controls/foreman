// https://flatbuffers.dev/tutorial/

namespace foreman.fbs;

table ComponentState {
    name: string;
    state: string;
    component_type: string;
}

table ErrorState {
    is_error: bool;
    category: string;
    message: string;
    components: [string];
}

table ForemanSnapshot {
    goal: string;
    ready: bool;
    at_goal: bool;
    error: ErrorState;
    components: [ComponentState];
}

root_type ForemanSnapshot;