<launch>
    <arg name="config_package" default="foreman"/>
    <arg name="config_file" default="config/scenario.yaml"/>
    <arg name="controller_manager" default="controller_manager"/>

    <let name="config_path" value="$(find-pkg-share $(var config_package))/$(var config_file)"/>

    <node pkg="foreman" exec="foreman_node" name="foreman_node" output="screen">
        <param name="config_path" value="$(var config_path)"/>
        <param name="controller_manager" value="$(var controller_manager)"/>
    </node>
</launch>
